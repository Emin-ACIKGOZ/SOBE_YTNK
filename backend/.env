# This DATABASE_URL points to the 'db' service defined in docker-compose.yml
# The host 'db' is automatically resolved by Docker Compose.
DATABASE_URL="postgresql://ytnk_user:ytnk_password@db:5432/ytnk_db"

# A secret key for security (e.g., for JWT tokens)
SECRET_KEY="your-super-secret-and-long-key"